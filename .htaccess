Options +FollowSymLinks -MultiViews
RewriteEngine On

# Block direct web access to dotfiles and secrets (.env, .git, etc.)
RewriteRule (^|/)\.(?!well-known) - [F]
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# Internally add .html extension if the file exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Internally add .php extension if the file exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]