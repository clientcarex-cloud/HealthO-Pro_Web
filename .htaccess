RewriteEngine On

# 1. Externally redirect direct requests for .html and .php to extensionless
# Only apply to GET/HEAD requests to avoid breaking POST forms/AJAX
RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.(html|php) [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Internally route extensionless requests to .html (takes precedence)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*?)/?$ $1.html [L]

# 3. Internally route extensionless requests to .php (fallback)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*?)/?$ $1.php [L]
